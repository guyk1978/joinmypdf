# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://joinmypdf.com

# PostHog (optional — analytics + funnels)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics (optional — loaded only after cookie consent)
# Cloudflare Pages: NEXT_PUBLIC_GA_MEASUREMENT_ID=G-Y8MDDJZGJY
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form — emails go to CONTACT_EMAIL_TO (default: dgartists@gmail.com)
# Browser delivery uses FormSubmit; optional Resend via /api/contact when RESEND_API_KEY is set.
NEXT_PUBLIC_CONTACT_EMAIL_TO=dgartists@gmail.com
CONTACT_EMAIL_TO=dgartists@gmail.com
RESEND_API_KEY=
CONTACT_EMAIL_FROM=JoinMyPDF <onboarding@resend.dev>
