# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://joinmypdf.com

# PostHog (optional — analytics + funnels)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics — cookie banner + GA4 (loads only after consent)
# Production: managed in wrangler.jsonc → vars.NEXT_PUBLIC_GA_MEASUREMENT_ID
# Local dev: copy to .env.local (see .env.example)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form — emails go to CONTACT_EMAIL_TO (default: dgartists@gmail.com)
# Browser delivery uses FormSubmit; optional Resend via /api/contact when RESEND_API_KEY is set.
NEXT_PUBLIC_CONTACT_EMAIL_TO=dgartists@gmail.com
CONTACT_EMAIL_TO=dgartists@gmail.com
RESEND_API_KEY=
CONTACT_EMAIL_FROM=JoinMyPDF <onboarding@resend.dev>

# Private site inventory (admin only) — set to true locally to enable /admin/inventory and header link
NEXT_PUBLIC_ADMIN_INVENTORY=false

# User feedback — EmailJS (client-side; create template with variables below)
# Template variables: {{subject}}, {{message}}, {{page_url}}, {{page_title}}, {{page_type}}, {{feedback_type}}, {{feedback_reason}}, {{timestamp}}, {{to_email}}
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_FEEDBACK_EMAIL_TO=dgartists@gmail.com
