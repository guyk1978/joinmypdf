{
  "name": "joinmypdf",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/sync-public-assets.mjs && next dev",
    "build": "next build && npx @cloudflare/next-on-pages",
    "build:static": "node scripts/sync-public-assets.mjs && node scripts/generate-blog-pages.mjs && node scripts/generate-blog-og-images.mjs && next build && node scripts/patch-unified-theme.mjs",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "start": "next start",
    "generate:blog-og": "node scripts/generate-blog-og-images.mjs",
    "generate:blog-pages": "node scripts/generate-blog-pages.mjs",
    "build:blog": "node scripts/generate-blog-og-images.mjs && node scripts/generate-blog-pages.mjs",
    "upgrade:blog": "node scripts/upgrade-blog-content.mjs"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "dxf-parser": "^1.1.2",
    "fflate": "^0.8.2",
    "heic2any": "^0.0.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "pdf-lib-with-encrypt": "^1.2.1",
    "pdfjs-dist": "^5.7.284",
    "posthog-js": "^1.373.4",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
